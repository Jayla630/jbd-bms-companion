.cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  width: 116rpx;
  position: relative;
}

.v {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.label {
  font-size: 20rpx;
  color: var(--text-tertiary);
}

.v.normal,
.label.normal {
  color: var(--color-normal);
  font-weight: 600;
}

.v.info,
.label.info {
  color: var(--color-info);
  font-weight: 600;
}

.v.warning,
.label.warning {
  color: var(--color-warning);
  font-weight: 600;
}

.tube {
  height: 128rpx;
  width: 60rpx;
  background: #f2f3f5;
  border-radius: 12rpx;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
}

.fill {
  width: 100%;
  background: #b9c0ca;
  border-radius: 12rpx 12rpx 0 0;
  transition: height 0.6s ease;
}

.fill.normal {
  background: var(--color-normal);
}

.fill.info {
  background: var(--color-info);
}

.fill.warning {
  background: var(--color-warning);
}

.badge {
  position: absolute;
  top: 32rpx;
  right: -8rpx;
  font-size: 18rpx;
  font-weight: 600;
  color: #fff;
  background: var(--color-normal);
  padding: 2rpx 10rpx;
  border-radius: 12rpx;
  animation: pulse 1.6s ease-in-out infinite;
}

@keyframes pulse {
  0%,
  100% {
    opacity: 1;
  }

  50% {
    opacity: 0.3;
  }
}
