.page-body.full {
  min-height: calc(100vh - 40rpx);
  box-sizing: border-box;
}

.section {
  font-size: 22rpx;
  color: var(--text-tertiary);
  padding: 4rpx 8rpx 0;
}

.nearby-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 8rpx 0;
}

.scan-state {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 22rpx;
  color: var(--color-info);
}

.spinner {
  width: 24rpx;
  height: 24rpx;
  border: 4rpx solid #d6e2fb;
  border-top-color: var(--color-info);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  box-sizing: border-box;
}

.spinner.big {
  width: 52rpx;
  height: 52rpx;
  border-width: 6rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.scanning-block {
  padding: 68rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.scanning-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.list {
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.divider {
  height: 1rpx;
  background: var(--divider);
  margin: 0 32rpx;
}

.hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 22rpx;
  color: var(--text-faint);
  text-align: center;
  line-height: 1.7;
  padding: 16rpx 48rpx 0;
}

.rescan-wrap {
  margin-top: auto;
  padding-top: 32rpx;
}

.rescan {
  height: 88rpx;
  border: 1rpx solid var(--border-normal);
  color: var(--color-normal);
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-card);
}

.rescan.busy {
  opacity: 0.5;
}
