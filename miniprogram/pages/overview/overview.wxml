<connection-banner link="{{link}}" device-name="{{deviceName}}" bind:bannertap="onBannerTap" />

<view class="page-body">
  <block wx:if="{{connected}}">
    <battery-gauge
      soc="{{soc}}"
      remain-mah="{{remainMah}}"
      design-capacity="{{designCapacity}}"
      cycle-count="{{cycleCount}}"
    />

    <view class="card metric-row">
      <view class="m divided"><metric-card label="总电压" value="{{tv}}" unit="V" /></view>
      <view class="m divided wide"><metric-card label="电流" value="{{cur}}" unit="A" tone="{{modeTone}}" badge="{{modeText}}" /></view>
      <view class="m"><metric-card label="功率" value="{{power}}" unit="W" /></view>
    </view>

    <view class="card cells-card">
      <view class="cells-head">
        <text class="cells-label">单体电压</text>
        <text class="delta mono {{deltaWide ? 'wide' : ''}}">{{deltaText}}</text>
      </view>
      <view class="cells-row">
        <cell-voltage-bar
          wx:for="{{cellItems}}"
          wx:key="label"
          label="{{item.label}}"
          value="{{item.value}}"
          accent="{{item.accent}}"
          height-rpx="{{item.heightRpx}}"
          balancing="{{item.balancing}}"
        />
      </view>
    </view>

    <view class="card temp-mos">
      <view class="temps">
        <view class="t">
          <text class="t-label">温度 T1</text>
          <text class="t-val mono">{{t1}}<text class="t-unit"> ℃</text></text>
        </view>
        <view class="t">
          <text class="t-label">温度 T2</text>
          <text class="t-val mono">{{t2}}<text class="t-unit"> ℃</text></text>
        </view>
      </view>
      <view class="chips">
        <text class="chip {{mos.c.cls}}">{{mos.c.text}}</text>
        <text class="chip {{mos.d.cls}}">{{mos.d.text}}</text>
        <text class="chip {{mos.b.cls}}">{{mos.b.text}}</text>
      </view>
    </view>

    <view class="card prot-row {{ps.cls}}" bindtap="goProtection">
      <view class="prot-left {{ps.cls}}">
        <view class="dot {{ps.cls}}"></view>
        <text>{{ps.text}}</text>
      </view>
      <text class="arrow">›</text>
    </view>
  </block>

  <block wx:else>
    <view class="card empty">
      <view class="empty-icon"><text class="bt">ᛒ</text></view>
      <view class="empty-text">
        <text class="empty-title">{{emptyTitle}}</text>
        <text class="empty-sub">{{emptySub}}</text>
      </view>
      <view class="empty-btn" bindtap="goConnect">{{emptyBtn}}</view>
    </view>
    <view class="card metric-row faded">
      <view class="m divided"><metric-card label="总电压" value="--.--" unit="" /></view>
      <view class="m divided"><metric-card label="电流" value="--.--" unit="" /></view>
      <view class="m"><metric-card label="SOC" value="--" unit="" /></view>
    </view>
  </block>
</view>
