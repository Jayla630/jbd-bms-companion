.metric-row {
  padding: 24rpx 0;
  display: flex;
}

.metric-row.faded {
  opacity: 0.75;
}

.m {
  flex: 1;
  display: flex;
}

.m.wide {
  flex: 1.2;
}

.m.divided {
  border-right: 1rpx solid var(--divider);
}

.cells-card {
  padding: 24rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.cells-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.cells-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.delta {
  font-size: 20rpx;
  font-weight: 600;
  color: var(--color-normal);
  background: var(--bg-normal);
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
}

.delta.wide {
  color: var(--color-warning);
  background: var(--bg-warning);
}

.cells-row {
  display: flex;
  justify-content: space-between;
  padding: 0 12rpx;
}

.temp-mos {
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.temps {
  display: flex;
  gap: 32rpx;
}

.t {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.t-label {
  font-size: 20rpx;
  color: var(--text-tertiary);
}

.t-val {
  font-size: 32rpx;
  font-weight: 600;
}

.t-unit {
  font-size: 20rpx;
  color: var(--text-tertiary);
  font-weight: 400;
}

.chips {
  display: flex;
  gap: 12rpx;
}

.chip {
  font-size: 20rpx;
  font-weight: 500;
  color: var(--text-secondary);
  background: #f2f3f5;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-chip);
}

.chip.normal {
  color: var(--color-normal);
  background: var(--bg-normal);
}

.chip.locked {
  color: var(--color-locked);
  background: var(--bg-locked);
}

.prot-row {
  padding: 26rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.prot-row.danger {
  border-color: var(--border-danger);
}

.prot-row.locked {
  border-color: var(--border-locked);
}

.prot-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.prot-left.danger {
  color: var(--color-danger);
}

.prot-left.locked {
  color: var(--color-locked);
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--color-normal);
}

.dot.danger {
  background: var(--color-danger);
}

.dot.locked {
  background: var(--color-locked);
}

.arrow {
  font-size: 28rpx;
  color: var(--text-faint);
}

/* ---- 空态 ---- */
.empty {
  padding: 56rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.empty-icon {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: #f2f3f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bt {
  font-size: 52rpx;
  color: #b0b4bb;
  font-weight: 600;
}

.empty-text {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
}

.empty-sub {
  font-size: 24rpx;
  color: var(--text-tertiary);
  text-align: center;
  line-height: 1.6;
  padding: 0 40rpx;
}

.empty-btn {
  height: 84rpx;
  padding: 0 72rpx;
  background: var(--color-normal);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: var(--radius-btn);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 8rpx;
}
