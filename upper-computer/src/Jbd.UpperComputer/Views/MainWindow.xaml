<Window
    x:Class="Jbd.UpperComputer.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:prism="http://prismlibrary.com/"
    Title="JBD BMS 上位机"
    Width="900"
    Height="520"
    MinWidth="720"
    MinHeight="440"
    prism:ViewModelLocator.AutoWireViewModel="True">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  连接栏：串口 / 波特率 / 连接断开 / 状态  -->
        <DockPanel Grid.Row="0" LastChildFill="False">
            <TextBlock VerticalAlignment="Center" Text="串口：" />
            <ComboBox
                Width="120"
                Margin="0,0,8,0"
                VerticalAlignment="Center"
                ItemsSource="{Binding AvailablePorts}"
                SelectedItem="{Binding SelectedPort}" />
            <Button
                Margin="0,0,16,0"
                Padding="8,2"
                VerticalAlignment="Center"
                Command="{Binding RefreshPortsCommand}"
                Content="刷新" />
            <TextBlock VerticalAlignment="Center" Text="波特率：" />
            <TextBox
                Width="70"
                Margin="0,0,16,0"
                VerticalAlignment="Center"
                Text="{Binding BaudRate}" />
            <Button
                Margin="0,0,8,0"
                Padding="12,2"
                VerticalAlignment="Center"
                Command="{Binding ConnectCommand}"
                Content="连接" />
            <Button
                Margin="0,0,16,0"
                Padding="12,2"
                VerticalAlignment="Center"
                Command="{Binding DisconnectCommand}"
                Content="断开" />
            <TextBlock
                VerticalAlignment="Center"
                FontWeight="Bold"
                Text="{Binding ConnectionStateText}" />
        </DockPanel>

        <!--  MOS 软件锁定醒目横幅（bit12）+ 引导式解锁入口。横幅消失由 0x03 回读驱动  -->
        <Border
            Grid.Row="1"
            Margin="0,8,0,0"
            Padding="8,4"
            Background="Firebrick"
            CornerRadius="3"
            Visibility="{Binding IsMosLocked, Converter={StaticResource BooleanToVisibilityConverter}}">
            <DockPanel LastChildFill="True">
                <Button
                    Padding="12,2"
                    VerticalAlignment="Center"
                    Command="{Binding UnlockMosCommand}"
                    Content="解锁 MOS"
                    DockPanel.Dock="Right"
                    FontWeight="Bold" />
                <!--  三步握手进度：每收到一步 ack 推进 1/3 → 2/3 → 3/3  -->
                <TextBlock
                    Margin="12,0"
                    VerticalAlignment="Center"
                    DockPanel.Dock="Right"
                    FontSize="15"
                    FontWeight="Bold"
                    Foreground="Gold"
                    Text="{Binding UnlockProgressText}"
                    Visibility="{Binding UnlockInProgress, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="15"
                    FontWeight="Bold"
                    Foreground="White"
                    Text="⚠ MOS 软件锁定（bit12）：充放电开关写入将被设备拒绝，点“解锁 MOS”按固定顺序解锁"
                    TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>

        <!--  数据区：总电压 / 电流 / SOC + 单体电压 + 控制/保护  -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock FontSize="14" Text="总电压 (V)" />
                <TextBlock
                    FontSize="42"
                    FontWeight="Bold"
                    Text="{Binding TotalVoltageV, StringFormat={}{0:F2}}" />
                <TextBlock
                    Margin="0,12,0,0"
                    FontSize="14"
                    Text="电流 (A)" />
                <TextBlock
                    FontSize="42"
                    FontWeight="Bold"
                    Text="{Binding CurrentA, StringFormat={}{0:F2}}" />
                <TextBlock
                    Margin="0,12,0,0"
                    FontSize="14"
                    Text="SOC (%)" />
                <TextBlock
                    FontSize="42"
                    FontWeight="Bold"
                    Text="{Binding SocPercent}" />
            </StackPanel>

            <StackPanel Grid.Column="1">
                <TextBlock FontSize="14" Text="单体电压 (V)" />
                <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding Cells}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <DockPanel Margin="0,2">
                                <TextBlock
                                    Width="60"
                                    FontSize="18"
                                    Text="{Binding Label}" />
                                <TextBlock
                                    FontSize="18"
                                    FontWeight="Bold"
                                    Text="{Binding VoltageV, StringFormat={}{0:F3}}" />
                            </DockPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <GroupBox Padding="8" Header="控制（回读为准）">
                    <StackPanel>
                        <CheckBox
                            Margin="0,4"
                            Content="充电 MOS"
                            FontSize="16"
                            IsChecked="{Binding ChargeMosOn}" />
                        <CheckBox
                            Margin="0,4"
                            Content="放电 MOS"
                            FontSize="16"
                            IsChecked="{Binding DischargeMosOn}" />
                        <CheckBox
                            Margin="0,4"
                            Content="均衡"
                            FontSize="16"
                            IsChecked="{Binding BalanceOn}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="11"
                            Foreground="Gray"
                            Text="开关显示设备实际状态，拨动后等下一轮回读确认"
                            TextWrapping="Wrap" />
                        <TextBlock
                            Margin="0,2,0,0"
                            FontSize="11"
                            FontWeight="Bold"
                            Foreground="Firebrick"
                            Text="当前处于软件锁定：写入会被拒绝，开关将弹回"
                            TextWrapping="Wrap"
                            Visibility="{Binding IsMosLocked, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>
                </GroupBox>

                <GroupBox
                    Margin="0,12,0,0"
                    Padding="8"
                    Header="保护状态">
                    <StackPanel>
                        <TextBlock
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="ForestGreen"
                            Text="正常"
                            Visibility="{Binding HasNoProtections, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <ItemsControl ItemsSource="{Binding ActiveProtections}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Margin="0,2"
                                        FontSize="15"
                                        FontWeight="Bold"
                                        Foreground="Firebrick"
                                        Text="{Binding StringFormat=● {0}}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </GroupBox>

                <!--  配置模式只读抓取（phase4-slice1）：进模式 → 扫 0x10~0xA2+0xAA → 原始 dump → 退模式  -->
                <GroupBox
                    Margin="0,12,0,0"
                    Padding="8"
                    Header="配置模式抓取（只读）">
                    <StackPanel>
                        <TextBlock
                            FontSize="11"
                            Foreground="Gray"
                            Text="真机前置：断开充电器与负载、电池静置；先断开上方轮询连接再抓。产出原始抓取档，归档私有库。"
                            TextWrapping="Wrap" />
                        <CheckBox
                            Margin="0,6,0,0"
                            Content="退出时写 0x01（真机核清前默认不勾）"
                            FontSize="12"
                            IsChecked="{Binding WriteExitOnCapture}" />
                        <Button
                            Margin="0,6,0,0"
                            Padding="12,2"
                            HorizontalAlignment="Left"
                            Command="{Binding CaptureConfigCommand}"
                            Content="开始抓取" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontWeight="Bold"
                            Text="{Binding CaptureProgressText}"
                            Visibility="{Binding CaptureInProgress, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="11"
                            Text="{Binding CaptureStatusMessage}"
                            TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="Firebrick" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CaptureSucceeded}" Value="True">
                                            <Setter Property="Foreground" Value="ForestGreen" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </Grid>

        <!--  状态栏：最后刷新时间 + 错误信息 + 解锁结果（成功绿/失败红，由回读裁决）  -->
        <DockPanel Grid.Row="3" Margin="0,8,0,0">
            <TextBlock Foreground="Gray" Text="{Binding LastUpdatedText}" />
            <TextBlock
                Margin="16,0,0,0"
                Foreground="Firebrick"
                Text="{Binding ErrorMessage}" />
            <TextBlock
                Margin="16,0,0,0"
                FontWeight="Bold"
                Text="{Binding UnlockStatusMessage}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="Firebrick" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding UnlockSucceeded}" Value="True">
                                <Setter Property="Foreground" Value="ForestGreen" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </DockPanel>
    </Grid>
</Window>
