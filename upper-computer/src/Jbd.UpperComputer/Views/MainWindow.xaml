<Window
    x:Class="Jbd.UpperComputer.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:prism="http://prismlibrary.com/"
    Title="JBD BMS 上位机"
    Width="900"
    Height="520"
    MinWidth="720"
    MinHeight="440"
    prism:ViewModelLocator.AutoWireViewModel="True">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  连接栏：串口 / 波特率 / 连接断开 / 状态  -->
        <DockPanel Grid.Row="0" LastChildFill="False">
            <TextBlock VerticalAlignment="Center" Text="串口：" />
            <ComboBox
                Width="120"
                Margin="0,0,8,0"
                VerticalAlignment="Center"
                ItemsSource="{Binding AvailablePorts}"
                SelectedItem="{Binding SelectedPort}" />
            <Button
                Margin="0,0,16,0"
                Padding="8,2"
                VerticalAlignment="Center"
                Command="{Binding RefreshPortsCommand}"
                Content="刷新" />
            <TextBlock VerticalAlignment="Center" Text="波特率：" />
            <TextBox
                Width="70"
                Margin="0,0,16,0"
                VerticalAlignment="Center"
                Text="{Binding BaudRate}" />
            <Button
                Margin="0,0,8,0"
                Padding="12,2"
                VerticalAlignment="Center"
                Command="{Binding ConnectCommand}"
                Content="连接" />
            <Button
                Margin="0,0,16,0"
                Padding="12,2"
                VerticalAlignment="Center"
                Command="{Binding DisconnectCommand}"
                Content="断开" />
            <TextBlock
                VerticalAlignment="Center"
                FontWeight="Bold"
                Text="{Binding ConnectionStateText}" />
        </DockPanel>

        <!--  数据区：总电压 / 电流 / SOC + 单体电压 + 控制/保护  -->
        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock FontSize="14" Text="总电压 (V)" />
                <TextBlock
                    FontSize="42"
                    FontWeight="Bold"
                    Text="{Binding TotalVoltageV, StringFormat={}{0:F2}}" />
                <TextBlock
                    Margin="0,12,0,0"
                    FontSize="14"
                    Text="电流 (A)" />
                <TextBlock
                    FontSize="42"
                    FontWeight="Bold"
                    Text="{Binding CurrentA, StringFormat={}{0:F2}}" />
                <TextBlock
                    Margin="0,12,0,0"
                    FontSize="14"
                    Text="SOC (%)" />
                <TextBlock
                    FontSize="42"
                    FontWeight="Bold"
                    Text="{Binding SocPercent}" />
            </StackPanel>

            <StackPanel Grid.Column="1">
                <TextBlock FontSize="14" Text="单体电压 (V)" />
                <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding Cells}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <DockPanel Margin="0,2">
                                <TextBlock
                                    Width="60"
                                    FontSize="18"
                                    Text="{Binding Label}" />
                                <TextBlock
                                    FontSize="18"
                                    FontWeight="Bold"
                                    Text="{Binding VoltageV, StringFormat={}{0:F3}}" />
                            </DockPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <GroupBox Padding="8" Header="控制（回读为准）">
                    <StackPanel>
                        <CheckBox
                            Margin="0,4"
                            Content="充电 MOS"
                            FontSize="16"
                            IsChecked="{Binding ChargeMosOn}" />
                        <CheckBox
                            Margin="0,4"
                            Content="放电 MOS"
                            FontSize="16"
                            IsChecked="{Binding DischargeMosOn}" />
                        <CheckBox
                            Margin="0,4"
                            Content="均衡"
                            FontSize="16"
                            IsChecked="{Binding BalanceOn}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="11"
                            Foreground="Gray"
                            Text="开关显示设备实际状态，拨动后等下一轮回读确认"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </Grid>

        <!--  状态栏：最后刷新时间 + 错误信息  -->
        <DockPanel Grid.Row="2" Margin="0,8,0,0">
            <TextBlock Foreground="Gray" Text="{Binding LastUpdatedText}" />
            <TextBlock
                Margin="16,0,0,0"
                Foreground="Firebrick"
                Text="{Binding ErrorMessage}" />
        </DockPanel>
    </Grid>
</Window>
